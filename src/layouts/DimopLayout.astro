---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  keywords: string;
  lang: 'hu' | 'en';
  canonical?: string;
}

const { title, description, keywords, lang, canonical } = Astro.props;

const baseUrl = 'https://dendora.hu';
const currentPath = Astro.url.pathname;

// Single-language page (Hungarian only)
const hreflangs = {
  hu: '/dimop/',
};
---

<!doctype html>
<html lang="hu">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <!-- Self-hosted Inter font -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-ext.woff2" as="font" type="font/woff2" crossorigin />
    
    <!-- SEO Meta Tags -->
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Dendora Bt." />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#059669" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={`${baseUrl}/dimop/`} />
    
    <!-- Single language, no hreflang alternates needed -->
    <link rel="alternate" hreflang="hu" href={`${baseUrl}${hreflangs.hu}`} />
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}${hreflangs.hu}`} />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${baseUrl}${currentPath}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${baseUrl}/og/dimop.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:site_name" content="Dendora" />
    <meta property="og:locale" content="hu_HU" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={`${baseUrl}${currentPath}`} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={`${baseUrl}/og/dimop.png`} />
    <meta property="twitter:image:alt" content={title} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/dendora-d-logo.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/dendora-d-logo.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/dendora-d-logo.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- WebSite Schema (Google knowledge panel) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://dendora.hu/#website",
      "name": "Dendora",
      "alternateName": ["Dendora Bt.", "Dendora Software Development"],
      "url": "https://dendora.hu",
      "inLanguage": "hu-HU",
      "publisher": {
        "@id": "https://dendora.hu/#organization"
      }
    }
    </script>

    <!-- DIMOP-specific Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Dendora Bt. - DIMOP Digitalizációs Partner",
      "description": "DIMOP Plusz-1.2.6 (B-26 / C-26) pályázati kivitelezés. 90%-os támogatásból teljes digitális szintlépés Budapesten kívüli mikro- és kisvállalkozásoknak.",
      "url": "https://dendora.hu/dimop",
      "logo": "https://dendora.hu/dendora-sw-dev-logo.png",
      "email": "hello@dendora.hu",
      "telephone": "+36306863734",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Esztergom",
        "addressRegion": "Komárom-Esztergom",
        "addressCountry": "HU"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 47.7856,
        "longitude": 18.7403
      },
      "areaServed": {
        "@type": "Country",
        "name": "Hungary"
      },
      "serviceType": [
        "DIMOP Pályázati Kivitelezés",
        "KKV Digitalizáció",
        "CRM Bevezetés",
        "Weboldal Fejlesztés",
        "AI Chatbot",
        "Dokumentumfeldolgozó AI",
        "Sales Automation",
        "IT Infrastruktúra"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "DIMOP Digitalizációs Csomagok",
        "itemListElement": [
          {
            "@type": "Offer",
            "name": "Basic Csomag",
            "description": "Digitális alapok — weboldal, CRM, alapvető IT biztonság",
            "priceSpecification": {
              "@type": "PriceSpecification",
              "price": "3000000-5000000",
              "priceCurrency": "HUF"
            }
          },
          {
            "@type": "Offer",
            "name": "Business Csomag",
            "description": "Teljes digitalizáció — webshop, automatizálás, AI chatbot",
            "priceSpecification": {
              "@type": "PriceSpecification",
              "price": "5000000-8000000",
              "priceCurrency": "HUF"
            }
          },
          {
            "@type": "Offer",
            "name": "Advanced Csomag",
            "description": "AI-vezérelt transzformáció — egyedi megoldásokkal",
            "priceSpecification": {
              "@type": "PriceSpecification",
              "price": "8000000-12000000",
              "priceCurrency": "HUF"
            }
          }
        ]
      }
    }
    </script>
  </head>
  <body>
    <slot />
    <script>
      // Smooth scroll for anchor links
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function(e) {
          const href = this.getAttribute('href');
          if (!href || href === '#') return;
          const target = document.querySelector(href);
          if (target) {
            e.preventDefault();
            target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });
      });
      // Scroll to hash on load
      if (window.location.hash) {
        const hash = window.location.hash;
        setTimeout(() => {
          const el = document.querySelector(hash);
          if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }, 300);
      }
    </script>
  </body>
</html>
