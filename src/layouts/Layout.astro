---
import '../styles/global.css';

export interface Props {
  title: string;
  description: string;
  lang: 'hu' | 'en';
  canonical?: string;
}

const { title, description, lang, canonical } = Astro.props;

// Get current URL for hreflang
const currentPath = Astro.url.pathname;
const baseUrl = 'https://dendora.hu';

// Generate hreflang URLs
const hreflangs = {
  hu: currentPath.startsWith('/en/') 
    ? currentPath.replace('/en/', '/').replace('/en', '/') 
    : currentPath,
  en: !currentPath.startsWith('/en/') 
    ? `/en${currentPath === '/' ? '' : currentPath}`
    : currentPath
};

// Ensure clean URLs
if (hreflangs.hu === '/') hreflangs.hu = '/';
if (hreflangs.en === '/en') hreflangs.en = '/en/';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <!-- Performance hints -->
    
    <!-- Self-hosted Inter font (no third-party requests) -->
    <link rel="preload" href="/fonts/inter-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/inter-latin-ext.woff2" as="font" type="font/woff2" crossorigin />
    
    <!-- SEO Meta Tags -->
    <meta name="description" content={description} />
    <meta name="keywords" content={lang === 'hu'
      ? "szoftverfejlesztés, webfejlesztés, webalkalmazás, egyedi szoftver, szoftverfejlesztés esztergom, webfejlesztés esztergom, szoftverfejlesztő cég, komárom-esztergom megye, React, TypeScript, Go, Kubernetes, full-stack fejlesztés, AI integráció, felhő infrastruktúra, magyar szoftverfejlesztés"
      : "software development, web development, web applications, React, TypeScript, Go, Kubernetes, full-stack development, AI integration, cloud infrastructure, custom software, Hungary, Esztergom"} />
    <meta name="author" content="Dendora Bt." />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#000000" />
    <meta name="msapplication-TileColor" content="#000000" />
    
    <!-- Geo Meta Tags -->
    <meta name="geo.region" content="HU-KE" />
    <meta name="geo.placename" content="Esztergom" />
    <meta name="geo.position" content="47.7856;18.7403" />
    <meta name="ICBM" content="47.7856, 18.7403" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href={canonical || `${baseUrl}${currentPath}`} />
    
    <!-- Hreflang for multilingual SEO -->
    <link rel="alternate" hreflang="hu" href={`${baseUrl}${hreflangs.hu}`} />
    <link rel="alternate" hreflang="en" href={`${baseUrl}${hreflangs.en}`} />
    <link rel="alternate" hreflang="x-default" href={`${baseUrl}${hreflangs.hu}`} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={`${baseUrl}${currentPath}`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${baseUrl}/dendora-sw-dev-logo.png`} />
    <meta property="og:site_name" content="Dendora" />
    <meta property="og:locale" content={lang === 'hu' ? 'hu_HU' : 'en_US'} />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={`${baseUrl}${currentPath}`} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={`${baseUrl}/dendora-sw-dev-logo.png`} />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/dendora-d-logo.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/dendora-d-logo.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/dendora-d-logo.png" />
    <link rel="manifest" href="/site.webmanifest" />
    
    <!-- WebSite Schema (Google knowledge panel: name, alternateName, url) -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "@id": "https://dendora.hu/#website",
      "name": "Dendora",
      "alternateName": ["Dendora Bt.", "Dendora Software Development"],
      "url": "https://dendora.hu",
      "inLanguage": ["hu-HU", "en-US"],
      "publisher": {
        "@id": "https://dendora.hu/#organization"
      }
    }
    </script>

    <!-- Organization / LocalBusiness Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "LocalBusiness",
      "@id": "https://dendora.hu/#organization",
      "name": "Dendora Bt.",
      "description": "Egyedi szoftverfejlesztés, webfejlesztés és AI megoldások Esztergomban. Full-stack fejlesztés modern eszközökkel.",
      "url": "https://dendora.hu",
      "logo": "https://dendora.hu/dendora-sw-dev-logo.png",
      "image": "https://dendora.hu/dendora-sw-dev-logo.png",
      "email": "hello@dendora.hu",
      "telephone": "+36306863734",
      "sameAs": [
        "https://github.com/dendora"
      ],
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Esztergom",
        "addressRegion": "Komárom-Esztergom",
        "addressCountry": "HU"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": 47.7856,
        "longitude": 18.7403
      },
      "areaServed": [
        {
          "@type": "City",
          "name": "Esztergom"
        },
        {
          "@type": "AdministrativeArea",
          "name": "Komárom-Esztergom megye"
        },
        {
          "@type": "Country",
          "name": "Hungary"
        }
      ],
      "foundingDate": "2014",
      "numberOfEmployees": "2-10",
      "priceRange": "$$",
      "knowsAbout": [
        "Szoftverfejlesztés",
        "Webfejlesztés",
        "React",
        "TypeScript",
        "Go",
        "Kubernetes",
        "Full-stack fejlesztés",
        "Mesterséges intelligencia",
        "Felhő infrastruktúra",
        "AI integráció"
      ],
      "knowsLanguage": ["hu", "en"],
      "serviceType": [
        "Web Application Development",
        "Custom Software Development",
        "Cloud Infrastructure",
        "Frontend Development",
        "Backend Development",
        "AI Integration"
      ],
      "hasOfferCatalog": {
        "@type": "OfferCatalog",
        "name": "Software Development Services",
        "itemListElement": [
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "Product Strategy & Validation",
              "description": "Scope, roadmap, and validation services"
            }
          },
          {
            "@type": "Offer", 
            "itemOffered": {
              "@type": "Service",
              "name": "Frontend Development",
              "description": "React, TypeScript, and modern frameworks with production-ready design systems"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service", 
              "name": "Backend & Infrastructure",
              "description": "Go microservices, PostgreSQL, Docker, and Kubernetes cloud-native architecture"
            }
          },
          {
            "@type": "Offer",
            "itemOffered": {
              "@type": "Service",
              "name": "AI & Agentic Solutions",
              "description": "LLM integrations, agentic workflows, and intelligent automation for real business problems"
            }
          }
        ]
      }
    }
    </script>
  </head>
  <body>
    <slot />
    <script>
      // Scroll to hash target after React components have mounted
      if (window.location.hash) {
        const hash = window.location.hash;
        const tryScroll = () => {
          const el = document.querySelector(hash);
          if (el) {
            el.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        };
        // Try after a short delay to allow React hydration
        setTimeout(tryScroll, 300);
      }
    </script>
  </body>
</html>