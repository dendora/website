---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Dendora" description="Az oldal nem található. / Page not found." lang="hu">
  <div class="min-h-screen flex items-center justify-center px-4 bg-gray-900">
    <div class="text-center max-w-lg">
      <div class="relative mb-8 select-none">
        <p class="text-[10rem] font-black leading-none text-white/5 md:text-[14rem]">404</p>
        <p class="absolute inset-0 flex items-center justify-center text-5xl md:text-6xl" aria-hidden="true">🫠</p>
      </div>
      <h1 class="text-2xl font-semibold text-white mb-2">Hoppá, itt nincs semmi.</h1>
      <p class="text-gray-400 mb-1 text-lg">Lehet, hogy elgépelted a címet, vagy mi töröltük az oldalt.</p>
      <p class="text-gray-500 mb-10 text-sm">Looks like this page doesn't exist. It may have been moved or removed.</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="/"
          class="inline-flex items-center gap-2 rounded-full bg-white px-7 py-3.5 text-sm font-medium text-gray-900 transition hover:bg-gray-100 hover:scale-[1.02] active:scale-[0.98]"
        >
          <span>←</span> Vissza a főoldalra
        </a>
        <a
          href="/en/"
          class="inline-flex items-center gap-2 rounded-full border border-white/20 px-7 py-3.5 text-sm font-medium text-white transition hover:bg-white/10 hover:scale-[1.02] active:scale-[0.98]"
        >
          <span>←</span> Back to homepage
        </a>
      </div>
    </div>
  </div>
</Layout>
