---
import DimopLayout from '../layouts/DimopLayout.astro';
import { DimopLanding } from '../components/dimop';
import dimopTranslations from '../locales/dimop/hu.json';

const lang = 'hu' as const;
const title = dimopTranslations.meta.title;
const description = dimopTranslations.meta.description;
const keywords = dimopTranslations.meta.keywords;
---

<DimopLayout title={title} description={description} keywords={keywords} lang={lang}>
  <DimopLanding language={lang} client:load />
</DimopLayout>
