---
import DimopLayout from '../../layouts/DimopLayout.astro';
import { DimopLanding } from '../../components/dimop';

const lang = 'en' as const;
const title = 'DIMOP Digitalization — 90% EU Grant Funding | Dendora';
const description = 'Complete digital transformation with 90% EU grant funding. Hardware, software, and AI solutions for SMBs — turnkey implementation.';
const keywords = 'DIMOP grant, 90% digitalization grant, SMB digitalization EU funding, CRM implementation grant, AI solutions SMB, digital transformation Hungary';
---

<DimopLayout title={title} description={description} keywords={keywords} lang={lang}>
  <DimopLanding language={lang} client:load />
</DimopLayout>
